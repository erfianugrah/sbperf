# deps
node_modules/

# secrets - never commit
.env
.env.*
!.env.example

# generated reports contain live query text - never commit
reports/
out/
*.report.html
*.report.pdf

# compiled binary
/sbperf

# scraper runtime data
scraper/data/

# OS / editor
.DS_Store
*.swp

# multi-db superuser targets (connstrings)
sbperf.databases.json
sbperf.databases.*.json
!sbperf.databases.example.json

# active white-label brand config (keep the .example); may point at private logos
sbperf.brand.json

# per-project review overlays (may reference project-specific context; keep the .example)
sbperf.overlays/

# exported Grafana dashboard JSON / local datasource config - may contain
# private URLs, datasource UIDs, and non-public label schemes. never commit.
db_exporter.json
sbperf.grafana.json
sbperf.grafana.*.json

# audit profile: the single-JSON no-PAT profile config (forced no-PAT +
# region-mapped Grafana cookies + DB connstrings). keep the .example.
# canonical: sbperf.profile.json; named variants: sbperf.<name>.profile.json
sbperf.profile.json
sbperf.*.profile.json
sbperf.work.env

# local scrape-init scratch stack (embeds a service_role credential)
/scraper/
