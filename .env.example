# sbperf auth + options. Copy to `.env` (gitignored) and fill in.
# Bun auto-loads `.env`, so these become process.env for `bun run src/index.ts`.

# --- Auth (pick ONE) ---
# 1. Personal Access Token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 2. OR leave it unset and run `supabase login` - sbperf reads the CLI token
#    from ~/.supabase/access-token automatically. (Resolution: env var first,
#    then the CLI token.)

# --- Superuser SQL tier (optional; your own projects) ---
# The default SQL tier is the PAT read-only runner (no password). For full
# access on a project you own, put the supabase_admin (or any Postgres)
# connection string here. QUOTE it (single quotes) so `$` / special chars in
# the password aren't shell-interpolated. --db-url overrides this if both given.
# The PAT is still used for API planes + metrics; the connstring is NEVER
# written to analysis.json (only which tier was used).
# SBPERF_DB_URL='postgresql://supabase_admin:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres'
#
# Multiple DBs from env: add numbered vars (each ONE full connstring - never
# comma-split a single var, a password can contain any delimiter). `full` sweeps
# them into per-DB reports + a combined index; `snapshot` records each.
# SBPERF_DB_URL_2='postgresql://...db2...'
# SBPERF_DB_URL_3='postgresql://...db3...'
#
# Or drop a gitignored `sbperf.databases.json` (list of {name?,ref?,dbUrl}) in
# the cwd - it's auto-loaded when no --db-url / --db-config / SBPERF_DB_URL is
# set. See sbperf.databases.example.json. Explicit flags always win over env.

# --- 30-day trends from an auth'd Prometheus / Grafana datasource (optional) ---
# By default trends come from the local SQLite store (`sbperf snapshot`). To pull
# them from a Prometheus (or a datasource behind Grafana) instead, set the URL.
# For a Grafana-fronted datasource, point at the proxy path:
#   https://<grafana-host>/api/datasources/proxy/uid/<DATASOURCE_UID>
# sbperf appends /api/v1/query_range.
# SBPERF_PROMETHEUS_URL=https://prometheus.example.com
#
# Auth (pick ONE). TOKEN = a Grafana service-account bearer (the documented path)
# or any auth-ed Prometheus token. COOKIE = the browser session
# Cookie header, for a Grafana behind an SSO proxy that a token can't
# traverse (copy the whole Cookie header from DevTools). Token wins if both set.
# SBPERF_PROMETHEUS_TOKEN=glsa_xxxxxxxxxxxxxxxxxxxx
# SBPERF_PROMETHEUS_COOKIE='grafana_session=...; _oauth2_proxy=...'
#
# Project-label selector template, when the scraper's schema isn't the default
# supabase_project_ref="{ref}". "{ref}" is substituted with the project ref.
# Example for a scraper that relabels series under a different label:
# SBPERF_PROMETHEUS_MATCHER='<label>="<prefix>-{ref}"'

# --- narrate (optional; LLM synthesis over analysis.json -> narrative.md) ---
# `sbperf narrate <dir>` uses any OpenAI-compatible /chat/completions endpoint
# (OpenAI, a local llama-server, OpenRouter, ...). BASE_URL + MODEL required;
# API_KEY optional (local servers usually need none). Not used by any other
# command; the deterministic report never calls an LLM.
# SBPERF_LLM_BASE_URL=http://localhost:11434/v1
# SBPERF_LLM_MODEL=your-model-id
# SBPERF_LLM_API_KEY=sk-xxxx

# --- No-PAT audit mode (optional) ---
# Force no-PAT even if a token is resolvable: run purely on the superuser
# --db-url + self-hosted splinter advisors + Grafana trends (equivalent to the
# --no-pat flag). The one-JSON alternative is a gitignored sbperf.profile.json
# (see sbperf.profile.example.json) passed via --profile.
# SBPERF_NO_PAT=1

# --- Trend window (optional) ---
# Query window for computed trends, in days (default 30; --trend-days wins, and
# a profile's trendDays wins over both). Auto-scopes down to a project's real
# data span so a young project isn't queried over a mostly-empty 30d.
# SBPERF_TREND_DAYS=30

# --- Branding / review overlay (optional; both keep a .example, both gitignored) ---
# White-label the report: point at a brand JSON (--brand wins, then SBPERF_BRAND,
# then ./sbperf.brand.json, then the Supabase default). See sbperf.brand.json.example.
# SBPERF_BRAND=./sbperf.brand.json
# Per-project review overlay (hide drill sections + append notes; presentation
# only, never touches analysis.json). --overlay wins, then SBPERF_OVERLAY, then
# ./sbperf.overlays/<ref>.json. See sbperf.overlay.example.json.
# SBPERF_OVERLAY=./sbperf.overlays/<ref>.json

# --- PDF rendering (optional) ---
# `pdf` / `full` shell out to headless Chromium (--print-to-pdf). By default the
# system Chrome/Chromium is discovered on PATH; override the binary here.
# SBPERF_CHROME=/usr/bin/chromium

# --- Logging (optional) ---
# Structured logs go to STDERR (stdout is reserved for report/JSON output).
# Level floor: debug | info | warn | error (default info). Multi-project sweeps
# quiet routine INFO by default - set this to `info`/`debug` to restore the full
# per-plane stream during a sweep.
# SBPERF_LOG_LEVEL=info
# Emit one JSON object per line instead of the pretty format (for log shippers).
# SBPERF_LOG=json
# Print full error stack traces on failure (default: one-line message).
# SBPERF_DEBUG=1
