# sbperf transport config. Pick ONE mode.
#
# Transport is auto-detected: if GATEKEEPER_URL is set -> gatekeeper mode,
# otherwise -> direct mode. Override with SBPERF_TRANSPORT=direct|gatekeeper.

# --- direct mode (hits Supabase APIs straight) ---
# Personal Access Token from https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- gatekeeper mode (proxies through your Gatekeeper IAM gateway) ---
# A single narrow-scoped Gatekeeper key replaces both the PAT and the
# per-project service_role metrics secret - Gatekeeper swaps them in upstream.
# GATEKEEPER_URL=https://gate.example.com
# GATEKEEPER_KEY=gk_xxxxxxxxxxxxxxxxxxxx

# --- optional ---
# SBPERF_TRANSPORT=direct
